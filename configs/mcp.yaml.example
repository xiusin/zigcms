# ZigCMS MCP 配置示例
# 复制此文件为 mcp.yaml 并根据需要修改

# ============================================
# 基本配置
# ============================================

# 服务名称
name: "ZigCMS_MCP"

# 版本号
version: "v1.0.0"

# 是否启用 MCP 服务器
enabled: true

# ============================================
# 传输层配置
# ============================================

transport:
  # 传输类型
  # - sse: Server-Sent Events（推荐，适合网络连接）
  # - stdio: 标准输入输出（适合本地进程通信）
  type: "sse"
  
  # 监听地址
  # - 127.0.0.1: 仅本地访问（推荐）
  # - 0.0.0.0: 允许外部访问（不推荐，安全风险）
  host: "127.0.0.1"
  
  # 监听端口
  # 默认: 8889
  # 如果端口被占用，可以修改为其他端口
  port: 8889
  
  # SSE 端点路径
  # AI 编辑器通过此路径连接到 MCP 服务器
  sse_path: "/mcp/sse"
  
  # 消息端点路径
  # AI 编辑器通过此路径发送消息
  message_path: "/mcp/message"
  
  # 心跳间隔（秒）
  # 服务器每隔此时间发送一次心跳，保持连接活跃
  # 推荐: 30-60 秒
  heartbeat_interval: 30

# ============================================
# 安全配置
# ============================================

security:
  # 允许访问的路径（相对于项目根目录）
  # 只有这些路径下的文件可以被读取和生成
  allowed_paths:
    - "src/"           # 源代码目录
    - "docs/"          # 文档目录
    - "knowlages/"     # 知识库目录
    - "tests/"         # 测试目录
    - "examples/"      # 示例目录
    - "migrations/"    # 迁移目录
  
  # 禁止访问的路径
  # 这些路径下的文件永远不会被访问
  forbidden_paths:
    - ".git/"          # Git 仓库
    - ".env"           # 环境变量文件
    - "config/secrets/" # 密钥配置
    - "node_modules/"  # Node.js 依赖
    - "zig-cache/"     # Zig 缓存
    - "zig-out/"       # Zig 输出
    - ".vscode/"       # VS Code 配置
    - ".idea/"         # IntelliJ IDEA 配置
  
  # 允许的文件扩展名
  # 只有这些扩展名的文件可以被读取和生成
  allowed_extensions:
    - ".zig"           # Zig 源代码
    - ".md"            # Markdown 文档
    - ".yaml"          # YAML 配置
    - ".yml"           # YAML 配置
    - ".json"          # JSON 配置
    - ".toml"          # TOML 配置
    - ".sql"           # SQL 脚本
    - ".txt"           # 文本文件
    - ".sh"            # Shell 脚本
    - ".bat"           # Windows 批处理
  
  # 最大文件大小（字节）
  # 超过此大小的文件不会被读取
  # 默认: 10MB (10485760 字节)
  # 推荐: 5-20MB
  max_file_size: 10485760

# ============================================
# 工具配置
# ============================================

tools:
  # 启用的工具列表
  # 可以禁用不需要的工具以提高安全性
  enabled:
    - "project_structure"   # 项目结构分析
    - "file_search"         # 文件搜索
    - "file_read"           # 文件读取
    - "generate_crud"       # CRUD 生成器
    - "generate_model"      # 模型生成器
    - "generate_migration"  # 迁移生成器
    - "generate_test"       # 测试生成器

# ============================================
# 日志配置
# ============================================

logging:
  # 日志级别
  # - debug: 调试信息（最详细）
  # - info: 一般信息（推荐）
  # - warn: 警告信息
  # - error: 错误信息（最简洁）
  level: "info"
  
  # 日志输出
  # - stdout: 标准输出（推荐，方便调试）
  # - file: 文件输出（推荐，生产环境）
  output: "stdout"
  
  # 日志文件路径（当 output 为 file 时）
  file_path: "logs/mcp.log"
  
  # 日志格式
  # - json: JSON 格式（推荐，方便解析）
  # - text: 文本格式（推荐，方便阅读）
  format: "text"

# ============================================
# 性能配置
# ============================================

performance:
  # 最大并发连接数
  # 同时连接的 AI 编辑器数量
  # 推荐: 10-100
  max_connections: 100
  
  # 请求超时（秒）
  # 超过此时间的请求将被取消
  # 推荐: 30-60 秒
  request_timeout: 30
  
  # 缓存大小（MB）
  # 用于缓存项目结构和文件内容
  # 推荐: 50-200MB
  cache_size: 100
  
  # 缓存过期时间（秒）
  # 缓存数据的有效期
  # 推荐: 300-600 秒（5-10 分钟）
  cache_ttl: 300

# ============================================
# 开发配置（可选）
# ============================================

development:
  # 是否启用开发模式
  # 开发模式下会输出更多调试信息
  enabled: false
  
  # 是否启用热重载
  # 配置文件修改后自动重载
  hot_reload: false
  
  # 是否启用性能分析
  # 记录每个请求的执行时间
  profiling: false

# ============================================
# 高级配置（可选）
# ============================================

advanced:
  # 是否启用压缩
  # 压缩响应数据以减少网络传输
  compression: true
  
  # 是否启用 CORS
  # 允许跨域请求（不推荐，安全风险）
  cors: false
  
  # 允许的 CORS 源（当 cors 为 true 时）
  cors_origins:
    - "http://localhost:3000"
  
  # 是否启用 SSL/TLS
  # 使用 HTTPS 加密传输（推荐，生产环境）
  ssl: false
  
  # SSL 证书路径（当 ssl 为 true 时）
  ssl_cert: "config/ssl/cert.pem"
  ssl_key: "config/ssl/key.pem"

# ============================================
# 示例配置
# ============================================

# 最小配置（仅必需项）
# name: "ZigCMS_MCP"
# version: "v1.0.0"
# enabled: true

# 开发环境配置
# transport:
#   port: 8889
# logging:
#   level: "debug"
#   output: "stdout"

# 生产环境配置
# transport:
#   host: "127.0.0.1"
#   port: 8889
# security:
#   max_file_size: 5242880  # 5MB
# logging:
#   level: "warn"
#   output: "file"
#   file_path: "/var/log/zigcms/mcp.log"
# performance:
#   max_connections: 50
#   request_timeout: 60
#   cache_size: 200

# ============================================
# 注意事项
# ============================================

# 1. 安全性
#    - 不要将 host 设置为 0.0.0.0（除非你知道你在做什么）
#    - 不要将敏感目录添加到 allowed_paths
#    - 定期检查 forbidden_paths 是否完整

# 2. 性能
#    - 根据实际情况调整 cache_size
#    - 根据网络情况调整 request_timeout
#    - 根据并发需求调整 max_connections

# 3. 日志
#    - 开发环境使用 stdout，方便调试
#    - 生产环境使用 file，方便归档
#    - 定期清理日志文件，避免磁盘占满

# 4. 工具
#    - 可以禁用不需要的工具
#    - 禁用工具可以提高安全性
#    - 建议保留所有工具以获得完整功能

# 5. 更新
#    - 定期检查配置文件是否有新选项
#    - 定期更新到最新版本
#    - 备份配置文件，避免丢失
